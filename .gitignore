data/*.dcm
data/*.zip
data/*.tar*
data/*/*.nii*
data/*/*.dcm
!data/README.md
!data/manifests/

# Results — keep small logs, ignore big checkpoints / heatmaps
results/checkpoints/
results/wandb/
results/runs/
results/*.pt
results/*.pth
results/*.ckpt
results/**/*.pt
results/**/*.pth
results/**/*.ckpt
!results/.gitkeep
!results/figures/
!results/tables/

# HuggingFace / torch caches
.cache/
hf_home/
torch_home/
